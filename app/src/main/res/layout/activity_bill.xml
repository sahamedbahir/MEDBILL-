<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#f9f9f9">

    <!-- Toolbar Section for Back Button and Heading -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp">

        <!-- Back Button (Left Arrow) -->
        <ImageView
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/baseline_arrow_back_24"
            android:contentDescription="Back"
            android:layout_alignParentStart="true"
            android:clickable="true"
            android:focusable="true" />

        <!-- Heading Section for "Bill" -->
        <TextView
            android:id="@+id/textView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_marginStart="169dp"
            android:layout_marginTop="1dp"
            android:text="Bill"
            android:textAlignment="center"
            android:textColor="#333"
            android:textSize="24sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- ListView for displaying bill items -->

    <!-- Total Price Section -->

    <ListView
        android:id="@+id/billListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#fff"
        android:divider="@android:color/darker_gray"
        android:dividerHeight="1dp" />

    <!-- Download Button for downloading the bill -->
    <TextView
        android:id="@+id/totalTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:padding="16dp"
        android:textColor="#333"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/downloadBillButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Download Bill"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:background="@color/green"
        android:padding="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />
</LinearLayout>
