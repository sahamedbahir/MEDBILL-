<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f9f9f9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Toolbar Section for Back Button and Heading -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp">

            <!-- Back Button (Left Arrow) -->
            <ImageView
                android:id="@+id/backButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/baseline_arrow_back_24"
                android:contentDescription="Back"
                android:layout_alignParentStart="true"
                android:clickable="true"
                android:focusable="true" />

            <!-- Heading Section for "Bill" -->
            <TextView
                android:id="@+id/textView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Bill"
                android:textColor="#333"
                android:textSize="24sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- TableLayout for displaying bill items in columns -->
        <TableLayout
            android:id="@+id/billTableLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="0,1,2"
            android:background="#fff">

            <!-- Header Row -->
            <TableRow
                android:background="#333333"
                android:padding="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Item"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Quantity"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Rate"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:gravity="center" />
            </TableRow>

        </TableLayout>

        <!-- Total Price Section -->
        <TextView
            android:id="@+id/totalTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:padding="16dp"
            android:text="Total: ₹100"
            android:textColor="#333"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Download Button for downloading the bill -->
        <Button
            android:id="@+id/downloadBillButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Download Bill"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:background="@color/green"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Send Email Button for sending the bill via email -->
        <Button
            android:id="@+id/sendEmailButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Send Bill via Email"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:background="@color/green"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
