<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/drawer_layout"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- Main Content Layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar at the Top -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/green"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
            app:title="My Application" />

        <!-- Main Content Area -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <!-- Welcome Text -->
            <TextView
                android:id="@+id/welcomeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome to MEDBILL"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <!-- Buttons for Different Categories -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/welcomeText"
                android:orientation="vertical"
                android:layout_marginTop="20dp">

                <Button
                    android:id="@+id/pillsbtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pills"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/syrupbtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Syrup"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/medicalcarebtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Medical Care"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/cartbtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="View Cart"
                    android:layout_marginTop="8dp" />

                <!-- Generate PDF Button Positioned Directly Below the Cart Button -->
                <Button
                    android:id="@+id/generatePdfBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Generate PDF"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <!-- Image Positioned in Bottom-Right -->
            <ImageView
                android:id="@+id/imageView"
                android:layout_width="208dp"
                android:layout_height="271dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_marginEnd="99dp"
                android:layout_marginBottom="50dp"
                app:srcCompat="@drawable/medbill" />

        </RelativeLayout>
    </LinearLayout>

    <!-- Navigation Sidebar -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu">

    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>
