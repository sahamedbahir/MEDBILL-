<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Toolbar with Custom Back Arrow -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/tool_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:elevation="4dp">

        <!-- Back Arrow Icon -->
        <ImageView
            android:id="@+id/back_arrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/baseline_arrow_back_24"
            android:contentDescription="Back"
            android:padding="8dp"
            android:layout_gravity="start|center_vertical" />

        <!-- Centered Title of Activity -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About Project MEDBILL"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginStart="16dp" />
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Project Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About Project MEDBILL"
                android:textSize="24sp"
                android:textColor="#000000"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="12dp" />

            <!-- Project Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MEDBILL is a comprehensive pharmacy app designed to make purchasing medications and healthcare products convenient and accessible. This app allows customers to browse through different categories of medicines and add them to their cart. The app also provides a secure checkout process, letting users view their cart, generate bills, and track purchases."
                android:textSize="16sp"
                android:textColor="#333333"
                android:paddingBottom="16dp" />

            <!-- How It Works Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How MEDBILL Works"
                android:textSize="20sp"
                android:textColor="#000000"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Login or Sign Up as a new user.\n2. Browse through the product categories: Pills, Syrups, and Medical Care.\n3. Add desired products to your cart.\n4. View your cart to see selected items and their total cost.\n5. Proceed to checkout to generate a bill for your purchase.\n6. Keep track of your bills and previous purchases under 'My Bill'."
                android:textSize="16sp"
                android:textColor="#333333"
                android:lineSpacingExtra="4dp" />

            <!-- Additional Info -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:paddingBottom="16dp"
                android:text="Our goal with MEDBILL is to simplify the process of purchasing essential medical products from the convenience of your mobile device."
                android:textColor="#333333"
                android:textSize="16sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
